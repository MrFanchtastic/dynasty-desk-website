---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Screenshots from '../components/Screenshots.astro';
import EmailCapture from '../components/EmailCapture.astro';
import Footer from '../components/Footer.astro';

const launchMode = import.meta.env.LAUNCH_MODE ?? 'coming_soon';
const isLive = launchMode === 'live';
---

<Base>
  <Nav />
  <main>
    <Hero />

    {isLive && <Features />}

    {isLive && <Screenshots />}

    <!-- CTA / Email Capture Section -->
    <section class="bg-navy-light py-20 md:py-28">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="mb-2 font-display text-2xl font-bold text-white md:text-3xl">
          {isLive ? 'Join the Dynasty Desk community.' : 'Get notified when we launch on Draft Day, April 23.'}
        </h2>
        <div class="mt-8">
          <EmailCapture />
        </div>
        <p class="mt-6 text-sm text-gray">
          <!-- TODO: Replace with actual Discord invite URL -->
          Or <a href="#" class="text-gold underline underline-offset-2 transition-colors hover:text-gold-dark">join us on Discord →</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

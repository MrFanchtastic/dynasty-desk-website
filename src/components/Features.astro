---
const features = [
  {
    icon: 'newspaper',
    headline: 'Your Franchise Gets Covered',
    title: 'AI Sports Journalism',
    body: "Dynasty Desk's narrative engine generates real postgame analysis and trade buzz from two distinct writer voices. Real storytelling, grounded in your actual season data.",
  },
  {
    icon: 'chart',
    headline: 'Every Stat Reconciles',
    title: 'Statistically Accurate',
    body: 'An event-ledger simulation engine guarantees integrity across every game. No phantom yards, no impossible totals — the box score always adds up.',
  },
  {
    icon: 'clipboard',
    headline: 'Real GM Decisions',
    title: 'Full Front Office Control',
    body: 'Salary cap, free agency, trades, the draft, injuries, depth charts. 32 teams, 17-game season, 7-team playoffs — NFL scale from day one.',
  },
  {
    icon: 'shield',
    headline: 'No Pay-to-Win. Ever.',
    title: 'Fair Play. Always.',
    body: 'Your roster is built by your decisions, not your wallet. Dynasty Pass unlocks customization and expanded features — never a competitive edge.',
  },
];
---

<section class="bg-navy py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature) => (
        <div class="rounded-xl border border-gold/10 bg-navy-light p-8 transition-colors hover:border-gold/25">
          <!-- Icon -->
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-gold/10">
            {feature.icon === 'newspaper' && (
              <svg class="h-6 w-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
              </svg>
            )}
            {feature.icon === 'chart' && (
              <svg class="h-6 w-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
            )}
            {feature.icon === 'clipboard' && (
              <svg class="h-6 w-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
              </svg>
            )}
            {feature.icon === 'shield' && (
              <svg class="h-6 w-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            )}
          </div>

          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-gold">{feature.title}</p>
          <h3 class="mb-3 font-display text-xl font-bold text-white">{feature.headline}</h3>
          <p class="text-sm leading-relaxed text-cream/70">{feature.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

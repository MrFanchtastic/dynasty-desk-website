---
const launchMode = import.meta.env.LAUNCH_MODE ?? 'coming_soon';
const isLive = launchMode === 'live';
const label = isLive
  ? 'Join the Dynasty Desk community.'
  : 'Get notified when we launch on Draft Day, April 23.';
---

<div class="mx-auto max-w-md">
  <p class="mb-4 text-sm text-cream/70">{label}</p>

  <div id="email-capture">
    <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
    <iframe
      src="https://subscribe-forms.beehiiv.com/342aeb63-14d6-46eb-ab15-293fa3e58ee0"
      class="beehiiv-embed"
      data-test-id="beehiiv-embed"
      frameborder="0"
      scrolling="no"
      style="width: 100%; max-width: 560px; height: 343px; margin: 0 auto; border-radius: 0; background-color: transparent; box-shadow: 0 0 #0000; display: block;"
    ></iframe>
  </div>
</div>

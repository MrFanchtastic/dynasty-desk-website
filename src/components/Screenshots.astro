---
const screenshots = [1, 2, 3, 4, 5, 6];
---

<section class="bg-navy py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 text-center">
      <h2 class="font-display text-3xl font-bold text-white md:text-4xl">
        Built for Football Minds
      </h2>
      <p class="mt-3 text-base text-cream/60 md:text-lg">
        Deep enough for the obsessives. Clean enough to play between meetings.
      </p>
    </div>

    <!-- Horizontal scroll -->
    <div class="scrollbar-hide -mx-6 flex gap-6 overflow-x-auto px-6 pb-4">
      {screenshots.map((num) => (
        <div class="flex-none">
          <!-- Phone frame mockup (CSS-only) -->
          <div class="relative w-[220px] rounded-[2rem] border-[3px] border-cream/15 bg-navy-light p-2 shadow-2xl shadow-black/40 md:w-[260px]">
            <!-- Notch -->
            <div class="absolute left-1/2 top-0 z-10 h-6 w-24 -translate-x-1/2 rounded-b-2xl bg-navy-light"></div>
            <!-- Screen -->
            <div class="overflow-hidden rounded-[1.6rem] bg-navy">
              <img
                src={`/images/screenshots/screen-${num}.png`}
                alt={`Dynasty Desk app screenshot ${num}`}
                width="260"
                height="563"
                loading="lazy"
                class="h-auto w-full"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
